"""
Constraint-tree based preprocessing for COCOA following COBREXA patterns.

This module implements preprocessing (elementary steps, blocked reaction removal, etc.)
using constraint trees rather than model objects, avoiding model conversion issues.
"""
module ConstraintPreprocessing

using COBREXA
using AbstractFBCModels
using HiGHS
using JuMP
using SparseArrays
